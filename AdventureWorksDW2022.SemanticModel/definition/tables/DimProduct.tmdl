		annotation SummarizationSetBy = Automatic

	column 'Current List Price' = ```
			
			VAR LastDateOfProduct =
			CALCULATE (
			MAX ( DimProduct[StartDate] ),
			ALLEXCEPT ( DimProduct, DimProduct[ProductAlternateKey] )
			)
			RETURN
			LOOKUPVALUE (
			DimProduct[ListPrice],
			DimProduct[StartDate], LastDateOfProduct,
			DimProduct[ProductAlternateKey], DimProduct[ProductAlternateKey]
			)
			
			```
		formatString: \$#,0.###############;(\$#,0.###############);\$#,0.###############
		lineageTag: 89161c38-77c5-4020-b012-5fa86a142614
		summarizeBy: sum

		annotation SummarizationSetBy = Automatic

		annotation PBI_FormatHint = {"currencyCulture":"en-US"}

	column 'Current List Price 2' = ```
			
			LOOKUPVALUE (
			[ListPrice],
			DimProduct[ProductAlternateKey], DimProduct[ProductAlternateKey],
			DimProduct[Status], "Current"
			)
			
			```
		formatString: \$#,0.###############;(\$#,0.###############);\$#,0.###############
		lineageTag: 742fb9b1-31af-490a-b646-43a4c5e4d19e
		summarizeBy: sum

		annotation SummarizationSetBy = Automatic

		annotation PBI_FormatHint = {"currencyCulture":"en-US"}

	column 'Price Class' =
			
			SWITCH (
			TRUE,
			[ListPrice] > 1000, "A",
			[ListPrice] > 100, "B",
			"C"
			)
		lineageTag: 047401e1-2386-4d7c-8125-dc1862f4b821
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

	column UnitPriceRankDense =
			
			VAR PriceOfCurrentProduct = 'DimProduct'[ListPrice]
			VAR HigherPrices =
			 FILTER (
			 VALUES ( 'DimProduct'[ListPrice] ),
			 'DimProduct'[ListPrice] > PriceOfCurrentProduct
			 )
			RETURN
			 COUNTROWS ( HigherPrices ) + 1
		formatString: 0
		lineageTag: 1d5cfa07-abd6-41df-86f9-c7fe584ab4ca
		summarizeBy: sum

		annotation SummarizationSetBy = Automatic

	column NumberOfSales =
			
			VAR SalesOfCurrentProduct = RELATEDTABLE ( FactInternetSales )
			RETURN
			 COUNTROWS ( SalesOfCurrentProduct )
		formatString: 0
		lineageTag: b05b49ec-c4b5-4bdc-aa52-2ebe00919cd1
		summarizeBy: sum

		annotation SummarizationSetBy = Automatic

