	column CustomerClass
		lineageTag: 6e69d4b2-56d5-442b-a469-28ce53195de7
		summarizeBy: none
		isNameInferred
		sourceColumn: [CustomerClass]

		annotation SummarizationSetBy = Automatic

	partition Table1 = calculated
		mode: import
		source = ```
				SELECTCOLUMNS (
				SUMMARIZECOLUMNS (
				'DimDate'[CalendarYear],
				'DimDate'[MonthNumberOfYear],
				DimCustomer[CustomerKey],
				FactInternetSales,
				"Cumulated Sales", CALCULATE (
				SUMX ( FactInternetSales, FactInternetSales[UnitPrice] * FactInternetSales[OrderQuantity] ),
				FILTER ( ALL ( 'DimDate' ), 'DimDate'[DateKey] <= MAX ( 'DimDate'[DateKey] ) )
				)
				),
				"CalendarYear", 'DimDate'[CalendarYear],
				"CalendarMonth", 'DimDate'[MonthNumberOfYear],
				"CustomerKey", DimCustomer[CustomerKey],
				"CustomerClass", SWITCH (
				TRUE,
				[Cumulated Sales] < 1000, "Retail",
				[Cumulated Sales] < 10000, "Affluent",
				"Vip"
				)
				)
				
				```

	annotation PBI_Id = ef4488999f48473c975003c229313105

