	column EmployeePath = PATH ( DimEmployee[EmployeeKey], DimEmployee[ParentEmployeeKey] )
		lineageTag: a9bd5aea-a9ae-443e-bc36-49ee8326b863
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

	column HierarchyDepth = PATHLENGTH ([EmployeePath] )
		formatString: 0
		lineageTag: b5361b1c-bc43-40d0-9f1f-10459d94c28a
		summarizeBy: sum

		annotation SummarizationSetBy = Automatic

	column EmployeeLevel1 =
			
			LOOKUPVALUE (
			[LastName],
			[EmployeeKey],
			PATHITEM ( [EmployeePath], 1, INTEGER )
			)
		lineageTag: 21260c2f-d0ca-4cd2-b009-d437634bec2d
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

	column EmployeeLevel2 =
			
			LOOKUPVALUE (
			[LastName],
			[EmployeeKey],
			PATHITEM ( [EmployeePath], 2, INTEGER )
			)
		lineageTag: 64b28bf9-844d-4a7a-b593-060099c38b53
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

	column EmployeeLevel3 =
			
			LOOKUPVALUE (
			[LastName],
			[EmployeeKey],
			PATHITEM ( [EmployeePath], 3, INTEGER )
			)
		lineageTag: 82979bdb-5182-499e-96e1-456b957242d3
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

	column EmployeeLevel4 =
			
			LOOKUPVALUE (
			[LastName],
			[EmployeeKey],
			PATHITEM ( [EmployeePath], 4, INTEGER )
			)
		lineageTag: f20a6167-feff-4317-9113-64fbeb29f5d9
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

	column EmployeeLevel5 =
			
			VAR CurrentLevel = 5
			VAR EmployeePreviousLevel = DimEmployee[EmployeeLevel4]
			VAR EmployeeKeyCurrentLevel =
			PATHITEM ( DimEmployee[EmployeePath], CurrentLevel, INTEGER )
			RETURN
			IF (
			DimEmployee[HierarchyDepth] < CurrentLevel,
			EmployeePreviousLevel,
			LOOKUPVALUE ( DimEmployee[LastName], DimEmployee[EmployeeKey],
			EmployeeKeyCurrentLevel )
			)
		lineageTag: 369cea13-112c-49f5-b18d-6b3152ace968
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

