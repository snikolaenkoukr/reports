	measure 'Sales 2007-2011' = ```
			
			CALCULATE (
				FactInternetSales[Total Sales],
				'DimDate'[CalendarYear] IN {2007, 2008, 2009, 2010, 2011}
			)
			
			```
		formatString: \$#,0.###############;(\$#,0.###############);\$#,0.###############
		lineageTag: 2ac8fd0a-43c5-496d-b5d3-14beb6f8c43a

		annotation PBI_FormatHint = {"currencyCulture":"en-US"}

	measure 'Sales 2007-2011 2' =
			
			CALCULATE (
				FactInternetSales[Total Sales],
				TREATAS ( { (2007, 12 ), (2011, 1)}, 'DimDate'[CalendarYear], 'DimDate'[MonthNumberOfYear] )
			)
		formatString: \$#,0.###############;(\$#,0.###############);\$#,0.###############
		lineageTag: 10afe45c-a74c-4856-a0b3-59f63b680633

		annotation PBI_FormatHint = {"currencyCulture":"en-US"}

	measure 'One Cutomer Total Sales' =
			
			CALCULATE(
			    DISTINCTCOUNT('FactInternetSales'[SalesOrderNumber]),
			    FILTER(
			        'FactInternetSales',
			       RELATED('DimCustomer'[CustomerKey]) = 11603)
			    )
		formatString: 0
		lineageTag: 60198f4d-b2d1-486d-b593-468b6169eb72

	measure 'Product Quantity Rank'
		lineageTag: e8ce635c-32cc-400c-8399-d7d28ede6369

	measure 'Revenue High Margin Products' = ```
			
			CALCULATE(
			    [Total Sales],
			    FILTER(
			        'DimProduct',
			        'DimProduct'[ListPrice] > 'DimProduct'[StandardCost] * 2
			    )
			)
			
			```
		formatString: \$#,0.###############;(\$#,0.###############);\$#,0.###############
		lineageTag: 982bbc8a-e135-4cfc-a16d-42e930a72319

		annotation PBI_FormatHint = {"currencyCulture":"en-US"}

	measure 'Customer Segment' =
			
			VAR CustomerRevenue = CALCULATE(SUM(FactInternetSales[SalesAmount]))
			RETURN
			    IF(CustomerRevenue < 500, "Low", "High")
		lineageTag: f3ee65ba-b7d7-41e1-838a-fe6bde3487b5

	measure 'Sales % Country' =
			
			IF(
			    ISINSCOPE(DimGeography[EnglishCountryRegionName]),
			    DIVIDE(
			        SUM(FactInternetSales[SalesAmount]),
			        CALCULATE(
			            SUM(FactInternetSales[SalesAmount]),
			            REMOVEFILTERS(DimGeography[EnglishCountryRegionName])
			        )
			    )
			)
		lineageTag: dafc3cbe-f8e9-4e5f-b764-cee57c7225ea

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Revenue YTD' =
			
			TOTALYTD(
			    [Total Sales],
			    'DimDate'[FullDateAlternateKey],
			    "12-31"
			)
		formatString: 0
		lineageTag: 2f347767-2304-4598-803e-420c01176ccb

	measure 'Revenue PY' = ```
			
			VAR RevenuePriorYear = CALCULATE(
			    [AllSales],
			    SAMEPERIODLASTYEAR('DimDate'[FullDateAlternateKey])
			)
			RETURN
			    RevenuePriorYear
			
			```
		formatString: 0
		lineageTag: c677a88f-bf08-46bc-93d0-dcd7821f6c94

	measure 'Sales YoY Growth' =
			
			VAR SalesPriorYear =
			    CALCULATE(
			        SUM(FactInternetSales[SalesAmount]),
			        PARALLELPERIOD(
			            'DimDate'[FullDateAlternateKey],
			            -12,
			            MONTH
			        )
			    )
			RETURN
			    DIVIDE(
			        (SUM(FactInternetSales[SalesAmount]) - SalesPriorYear),
			        SalesPriorYear
			    )
		formatString: #,0.00%;-#,0.00%;#,0.00%
		lineageTag: 84021a1c-6413-45f4-8b91-430eeb5acd45

	measure 'Sales RT' = ```
			
			VAR MaxDate = MAX ( 'DimDate'[FullDateAlternateKey] )
			VAR Result = 
				CALCULATE (
					[Total Sales],
					'DimDate'[FullDateAlternateKey] <= MaxDate,
					ALL ( 'DimDate' )
				)
			RETURN 
				Result
			
			```
		formatString: \$#,0.###############;(\$#,0.###############);\$#,0.###############
		lineageTag: 31b9dad2-29b0-409c-9d00-04a27e3c2f87

		annotation PBI_FormatHint = {"currencyCulture":"en-US"}

	measure 'Last 12 month Sales' = ```
			
			CALCULATE (
			    [Total Sales],
			    DATESINPERIOD ( 'DimDate'[FullDateAlternateKey], MAX('FactInternetSales'[OrderDateKey]), -12, MONTH)
			    ) 
			```
		formatString: \$#,0.###############;(\$#,0.###############);\$#,0.###############
		lineageTag: 2f464615-59c5-4abc-a6a6-58d75fb55ba0

		annotation PBI_FormatHint = {"currencyCulture":"en-US"}

	measure 'Percentage of grand total sales' = ```
			
			VAR _sales = SUM( 'FactInternetSales'[SalesAmount] )
			VAR _totalsales =  
			CALCULATE (
			    SUM( 'FactInternetSales'[SalesAmount] ),
			    FILTER (
			        ALLSELECTED ( 'DimDate' ),
			        'DimDate'[FullDateAlternateKey] <= MAX ( 'DimDate'[FullDateAlternateKey] )
			    ) 
			)
			RETURN
			DIVIDE ( _sales, _totalsales )
			
			```
		formatString: 0.00%;-0.00%;0.00%
		lineageTag: eab11779-2489-4fc0-a692-86f1fef89a9c

	measure 'Running Sum' = ```
			
			CALCULATE (
			    SUM('FactInternetSales'[SalesAmount]),
			    FILTER (
			        ALLSELECTED ( 'DimDate' ),
			        'DimDate'[FullDateAlternateKey] <= MAX ( 'DimDate'[FullDateAlternateKey] )
			    ) 
			)
			```
		formatString: \$#,0.###############;(\$#,0.###############);\$#,0.###############
		lineageTag: 021904c7-5e1c-4bda-a439-c29f13185357

		annotation PBI_FormatHint = {"currencyCulture":"en-US"}

	measure 'Rank Cat on Sales' = ```
			
			IF (
			 HASONEVALUE ( 'DimProductCategory'[EnglishProductCategoryName] ),
			 RANKX (
			 ALL ( 'DimProductCategory'[EnglishProductCategoryName] ),
			 [Total Sales]
			 )
			)
			
			```
		formatString: 0
		lineageTag: e36cc0de-4396-402e-9309-7e4f15a6d5fd

