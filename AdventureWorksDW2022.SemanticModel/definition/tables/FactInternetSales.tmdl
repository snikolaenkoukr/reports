table FactInternetSales
	lineageTag: 44a6c4b5-3ed3-485a-9bbf-d9ef8ef33aa7

	measure 'Net Sales' =
			
			SUMX ( FactInternetSales, FactInternetSales[OrderQuantity] * FactInternetSales[UnitPrice] * 2 )
		formatString: \$#,0.###############;(\$#,0.###############);\$#,0.###############
		lineageTag: 8a400246-fa5f-40df-8d00-cf7525451568

		annotation PBI_FormatHint = {"currencyCulture":"en-US"}

	measure 'Total Sales' =
			
			SUMX ( FactInternetSales, FactInternetSales[SalesAmount] )
		formatString: \$#,0.###############;(\$#,0.###############);\$#,0.###############
		lineageTag: a194f60a-a9e9-42ac-acf5-ca1e37bb6f14

		annotation PBI_FormatHint = {"currencyCulture":"en-US"}

	measure 'Shipped  Sales' =
			
			CALCULATE (
			[Total Sales],
			USERELATIONSHIP ( FactInternetSales[ShipDateKey], 'DimDate'[DateKey] )
			)
		formatString: \$#,0.###############;(\$#,0.###############);\$#,0.###############
		lineageTag: 7840cb95-6b14-4aa1-b104-2ec8e699b85c

		annotation PBI_FormatHint = {"currencyCulture":"en-US"}

	measure 'Net Sales Actualized' =
			
			SUMX ( FactInternetSales, FactInternetSales[OrderQuantity] * RELATED ( DimProduct[Current List Price 2] ))
		formatString: \$#,0.###############;(\$#,0.###############);\$#,0.###############
		lineageTag: 44da842e-dc6b-4f9a-90c5-25505c6b3336

		annotation PBI_FormatHint = {"currencyCulture":"en-US"}

	measure 'Discounted Quantity' =
			
			CALCULATE (
			SUM ( FactInternetSales[OrderQuantity] ),
			FactInternetSales[DiscountAmount] <> 0
			)
		formatString: 0
		lineageTag: 291e5d17-4801-41d7-bfd2-0a31b66d5ebc

	measure 'Discounted Quantity Optimized' =
			
			CALCULATE (
			SUM ( FactInternetSales[OrderQuantity] ),
			FactInternetSales[HasDiscount] = TRUE
			)
		formatString: 0
		lineageTag: 6094e175-42e2-44c7-8f06-809e8a6d83ba

